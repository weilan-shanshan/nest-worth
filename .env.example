# 阿里云百炼 Qwen-VL API Key
# 申请：https://bailian.console.aliyun.com/  → API-KEY 管理
# 复制 .env.example 为 .env.local 并填入你的 key
VITE_DASHSCOPE_API_KEY=

# Cloudflare Worker 行情代理 URL（可选）
# 用于自动拉 A 股 / 港股 / 美股 / 国内基金价格（绕过 CORS）
# 部署：把 worker/quotes-proxy.js 粘到 Cloudflare Workers
# 加密货币不需要 Worker，直连 CoinGecko
VITE_QUOTE_PROXY=
