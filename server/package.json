{
  "name": "nestworth-analytics-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Anonymous site-usage analytics ingester + admin query API for Nestworth.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "psql \"$DATABASE_URL\" -f sql/schema.sql"
  },
  "engines": {
    "node": ">=18.19"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "dotenv": "^16.4.5",
    "hono": "^4.6.0",
    "pg": "^8.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
