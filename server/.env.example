# PostgreSQL 连接串，例：postgres://user:pass@host:5432/nestworth
DATABASE_URL=

# 后台访问令牌（也用于前端 /_admin/<TOKEN> 路由里那一段）
# 随机生成：openssl rand -hex 32
ADMIN_TOKEN=

# 允许跨域上报的来源（生产环境的 PWA 域名，逗号分隔）
# 例：https://nestworth.app,https://nestworth.pages.dev
ALLOWED_ORIGINS=

# 监听端口（默认 8787）
PORT=8787

# === 商业化（Sprint 0+） ===
# JWT 签名密钥（Ed25519，PKCS8/SPKI base64 压成单行）
# 生成命令：
#   node --input-type=module -e "import {generateKeyPair,exportPKCS8,exportSPKI} from 'jose'; \
#     const {privateKey,publicKey}=await generateKeyPair('EdDSA',{crv:'Ed25519',extractable:true}); \
#     const s=(p,k)=>p.replace(new RegExp('-----(BEGIN|END) '+k+'-----','g'),'').replace(/\s+/g,''); \
#     console.log('JWT_PRIVATE_KEY='+s(await exportPKCS8(privateKey),'PRIVATE KEY')); \
#     console.log('JWT_PUBLIC_KEY='+s(await exportSPKI(publicKey),'PUBLIC KEY'));"
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# 邮箱哈希盐（HMAC-SHA256）。生成：openssl rand -hex 32
# 一旦上线不可更改，否则现有用户全部失联
EMAIL_HASH_SALT=

# Magic link 验证页前缀（前端路由）
MAGIC_LINK_BASE_URL=http://localhost:5173/auth/verify

# === 邮件投递（Sprint 1） ===
# stub        = 不真发，console 打 log（dev 默认）
# smtp        = nodemailer，按下方 SMTP_* 配置（需要企业认证才能用腾讯云 SES SMTP）
# tencent_ses = 腾讯云 SES HTTP API，个人实名账号也支持
MAIL_TRANSPORT=stub

# SMTP（MAIL_TRANSPORT=smtp 时必填）
# 各提供商对照：
#   腾讯云 SES：host=smtp.qcloudmail.com  port=465
#     user 是创建的发信地址（如 noreply@yourdomain.com）；pass 是 SES 控制台
#     生成的 SMTP 密码（不是腾讯云 API Key）
#   阿里云 DirectMail：host=smtpdm.aliyun.com port=465
#   QQ 邮箱：host=smtp.qq.com           port=465
#     pass = QQ 邮箱设置生成的"授权码"
#   163 邮箱：host=smtp.163.com         port=465
#   Outlook：host=smtp.office365.com    port=587
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# From 头，邮件客户端看到的发件人；推荐格式 "Nestworth <noreply@yourdomain.com>"
# 用 SES / DirectMail 时这里的地址必须等于 SMTP_USER；用个人邮箱时一致更不易进垃圾箱
MAIL_FROM=

# === 腾讯云 SES HTTP API（MAIL_TRANSPORT=tencent_ses 时必填） ===
# 推荐用「子账号专属密钥」（仅授予 SES 发信权限），不要用主账号 Key
# 控制台 → 访问管理 → 用户 → 新建子用户 → 关联策略 QcloudSESFullAccess（或更细）→ API 密钥
TENCENT_SES_SECRET_ID=
TENCENT_SES_SECRET_KEY=

# SES 开通区域（控制台 → 邮件推送 → 左上角；常见 ap-hongkong / ap-guangzhou）
TENCENT_SES_REGION=ap-hongkong

# 发信地址，必须是 SES 控制台「发信地址」里已验证的；推荐格式 "净值 <noreply@yourdomain.com>"
TENCENT_SES_FROM=

# 控制台已审核通过的邮件模板 ID（整数）。
# 个人实名账号必填——SES 拒绝 Simple 模式发信，只能引用预审核模板。
# 模板里硬编码完整 URL 的域名 + path；{{token}} {{ttl}} 是变量。
# 升企业认证后可留空回退 Simple 模式。
TENCENT_SES_TEMPLATE_ID=

# === LLM 代付（Sprint 1 Day 3） ===
# 阿里云百炼 API Key（用于服务端代付 OCR / 分析调用）
# 申请：https://bailian.console.aliyun.com/  → API-KEY 管理
# Sprint 1 仅 OCR 用；Sprint 2 接 analysis 后同 key 复用
BAILIAN_API_KEY=
